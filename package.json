{
  "name": "elibor-node",
  "version": "1.0.0",
  "description": "Elibor - AI Soul Simulation Game",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/web/server.ts",
    "dev:engine": "tsx watch src/engine/worker.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:engine\"",
    "build": "tsc",
    "start": "concurrently \"npm run start:web\" \"npm run start:engine\"",
    "start:web": "node dist/web/server.js",
    "start:engine": "node dist/engine/worker.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "cron": "^3.3.1",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.8.1",
    "winston": "^3.17.0",
    "zod": "^3.25.23"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.21",
    "concurrently": "^9.1.2",
    "prisma": "^6.9.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}
